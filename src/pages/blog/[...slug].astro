---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} - AI News Daily`}>
  <article class="max-w-3xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
    <header class="mb-12 text-center">
      <time class="text-sm font-bold text-blue-600 tracking-wider uppercase mb-3 block">
        {new Date(entry.data.pubDate).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight mb-6 leading-tight max-w-4xl mx-auto">
        {entry.data.title}
      </h1>
      <div class="w-16 h-1 bg-blue-600 mx-auto mt-8"></div>
    </header>
    
    <div class="prose prose-lg prose-slate mx-auto
                prose-headings:font-bold prose-headings:text-gray-900 prose-headings:mt-10 prose-headings:mb-5
                prose-h2:text-3xl prose-h3:text-2xl
                prose-p:text-gray-700 prose-p:leading-relaxed prose-p:mb-6
                prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline
                prose-strong:text-gray-900 prose-strong:font-bold
                prose-ul:list-disc prose-ul:pl-6 prose-ul:mb-8 prose-ul:space-y-2
                prose-li:text-gray-700
                prose-blockquote:border-l-4 prose-blockquote:border-blue-500 prose-blockquote:pl-5 prose-blockquote:italic prose-blockquote:text-gray-600 prose-blockquote:my-8
                prose-hr:my-10 prose-hr:border-gray-200
                prose-img:rounded-2xl prose-img:shadow-xl prose-img:mx-auto prose-img:w-full prose-img:object-cover prose-img:max-h-[500px]">
      <Content />
    </div>
  </article>
</Layout>
