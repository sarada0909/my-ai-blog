---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.slug !== entry.slug)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 2);

function extractImageUrl(body: string) {
  if (!body) return 'https://images.unsplash.com/photo-1677442136019-21780ecad995?q=80&w=800&auto=format&fit=crop';
  const match = body.match(/!\[.*?\]\((.*?)\)/);
  return match ? match[1] : 'https://images.unsplash.com/photo-1677442136019-21780ecad995?q=80&w=800&auto=format&fit=crop';
}

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

const imageUrl = extractImageUrl(entry.body);
---

<Layout 
	title={`${entry.data.title} - AI Insights`}
	description={entry.data.description || "AI News Bot이 전해드리는 최신 AI 뉴스 요약본입니다."}
	image={imageUrl}
>
	<div class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden">
		<!-- Header / Nav -->
		<header class="sticky top-0 z-50 flex items-center bg-background-light/80 dark:bg-background-dark/80 backdrop-blur-md p-4 border-b border-slate-200 dark:border-slate-800 justify-between">
			<div class="flex items-center gap-4">
				<a class="text-slate-900 dark:text-slate-100 flex items-center justify-center hover:text-primary transition-colors cursor-pointer" href="/">
					<span class="material-symbols-outlined">arrow_back</span>
				</a>
				<h2 class="text-lg font-bold leading-tight tracking-tight text-slate-900 dark:text-white">Article</h2>
			</div>
			<div class="flex gap-4">
				<button id="btn-share" class="flex items-center justify-center text-slate-600 dark:text-slate-400 hover:text-primary transition-colors cursor-pointer group relative">
					<span class="material-symbols-outlined">share</span>
					<span class="absolute -bottom-8 bg-slate-800 text-white text-[10px] px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">공유하기</span>
				</button>
				<button id="btn-bookmark" class="flex items-center justify-center text-slate-600 dark:text-slate-400 hover:text-primary transition-colors cursor-pointer group relative">
					<span class="material-symbols-outlined">bookmark</span>
					<span class="absolute -bottom-8 bg-slate-800 text-white text-[10px] px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">저장하기</span>
				</button>
			</div>
		</header>

		<!-- Main Content -->
		<main class="flex-1 max-w-4xl mx-auto w-full">
			<article class="px-4 py-8">
				<!-- Title & Meta -->
				<h1 class="text-slate-900 dark:text-slate-100 text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight mb-6 mt-4">
					{entry.data.title}
				</h1>
				<div class="flex items-center gap-4 mb-8 border-b border-slate-200 dark:border-slate-800 pb-4">
					<p class="text-sm font-medium text-slate-500 dark:text-slate-400">Published {formatDate(entry.data.pubDate)}</p>
				</div>

				<!-- Article Body -->
				<div class="prose prose-slate dark:prose-invert max-w-none space-y-6 text-lg leading-relaxed text-slate-700 dark:text-slate-300
					prose-headings:font-bold prose-headings:text-slate-900 dark:prose-headings:text-white
					prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
					prose-p:mb-6
					prose-a:text-primary hover:prose-a:underline
					prose-strong:text-slate-900 dark:prose-strong:text-white
					prose-blockquote:border-l-4 prose-blockquote:border-primary prose-blockquote:pl-6 prose-blockquote:py-2 prose-blockquote:my-10 prose-blockquote:italic prose-blockquote:text-xl prose-blockquote:font-medium prose-blockquote:text-slate-900 dark:prose-blockquote:text-slate-100 prose-blockquote:bg-transparent
					prose-img:rounded-xl prose-img:w-full prose-img:aspect-video prose-img:object-cover prose-img:shadow-sm
					prose-ul:list-disc prose-ul:pl-6 prose-ul:space-y-2
					prose-hr:my-10 prose-hr:border-slate-200 dark:prose-hr:border-slate-800">
					<Content />
				</div>

				<!-- Share Section -->
				<div class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-800 flex flex-wrap gap-4 items-center">
					<span class="text-sm font-bold uppercase tracking-wider text-slate-500">Share this story</span>
					<div class="flex gap-2">
						<button id="btn-share-bottom" class="size-10 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center hover:bg-primary/20 hover:text-primary transition-colors cursor-pointer">
							<span class="material-symbols-outlined text-[20px]">share</span>
						</button>
						<button id="btn-copy-link" class="size-10 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center hover:bg-primary/20 hover:text-primary transition-colors cursor-pointer relative">
							<span class="material-symbols-outlined text-[20px]">link</span>
						</button>
					</div>
				</div>
			</article>

			<!-- Related News Section -->
			{relatedPosts.length > 0 && (
			<section class="px-4 py-12 bg-slate-50 dark:bg-slate-900/50">
				<h3 class="text-xl font-bold mb-6 text-slate-900 dark:text-white">Related News</h3>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
					{relatedPosts.map(post => (
					<a class="group flex flex-col gap-3" href={`/blog/${post.slug}`}>
						<div class="aspect-video rounded-lg overflow-hidden bg-slate-200 dark:bg-slate-800 hover:shadow-md transition-shadow">
							<div class="w-full h-full bg-cover bg-center group-hover:scale-105 transition-transform duration-300" data-alt={post.data.title} style={`background-image: url("${extractImageUrl(post.body)}");`}></div>
						</div>
						<div>
							<span class="text-xs font-bold text-primary uppercase">News</span>
							<h4 class="font-bold mt-1 text-slate-900 dark:text-white group-hover:text-primary transition-colors line-clamp-2">{post.data.title}</h4>
							<p class="text-sm text-slate-500 dark:text-slate-400 mt-1">{formatDate(post.data.pubDate)}</p>
						</div>
					</a>
					))}
				</div>
			</section>
			)}
		</main>

		<!-- Bottom Navigation -->
		<nav class="sticky bottom-0 z-50 flex gap-2 border-t border-slate-200 dark:border-slate-800 bg-background-light dark:bg-background-dark px-4 pb-4 pt-2 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)]">
			<a class="flex flex-1 flex-col items-center justify-center gap-1 text-slate-500 dark:text-slate-400 hover:text-primary transition-transform cursor-pointer hover:scale-105" href="/">
				<span class="material-symbols-outlined hover:fill-[1]">home</span>
				<p class="text-[10px] font-medium leading-normal uppercase tracking-wider">Home</p>
			</a>
			<a class="flex flex-1 flex-col items-center justify-center gap-1 text-slate-500 dark:text-slate-400 hover:text-primary transition-transform cursor-pointer hover:scale-105" href="/">
				<span class="material-symbols-outlined">search</span>
				<p class="text-[10px] font-bold leading-normal uppercase tracking-wider">Search</p>
			</a>
			<a class="flex flex-1 flex-col items-center justify-center gap-1 text-slate-500 dark:text-slate-400 hover:text-primary transition-transform cursor-pointer hover:scale-105" href="/">
				<span class="material-symbols-outlined">new_releases</span>
				<p class="text-[10px] font-medium leading-normal uppercase tracking-wider">New</p>
			</a>
			<button onclick="window.scrollTo({top: 0, behavior: 'smooth'})" class="flex flex-1 flex-col items-center justify-center gap-1 text-slate-500 dark:text-slate-400 hover:text-primary transition-transform cursor-pointer hover:scale-105">
				<span class="material-symbols-outlined">keyboard_arrow_up</span>
				<p class="text-[10px] font-medium leading-normal uppercase tracking-wider">Top</p>
			</button>
		</nav>
	</div>

	<!-- Client-side Interactive Script -->
	<script>
		document.addEventListener('DOMContentLoaded', () => {
			// Sharing logic
			const shareAction = async () => {
				const shareData = {
					title: document.title,
					text: 'AI Insights에서 이 뉴스 기사를 확인해보세요!',
					url: window.location.href,
				};
				if (navigator.share) {
					try {
						await navigator.share(shareData);
					} catch (err) {
						console.log('Error sharing:', err);
					}
				} else {
					navigator.clipboard.writeText(window.location.href);
					alert('링크가 복사되었습니다!');
				}
			};

			document.getElementById('btn-share')?.addEventListener('click', shareAction);
			document.getElementById('btn-share-bottom')?.addEventListener('click', shareAction);

			// Copy link logic
			document.getElementById('btn-copy-link')?.addEventListener('click', () => {
				navigator.clipboard.writeText(window.location.href);
				alert('링크가 복사되었습니다!');
			});

			// Bookmark logic
			document.getElementById('btn-bookmark')?.addEventListener('click', (e) => {
				const icon = (e.currentTarget as HTMLElement).querySelector('.material-symbols-outlined');
				if (icon) {
					if (icon.textContent === 'bookmark') {
						icon.textContent = 'bookmark_added';
						icon.classList.add('text-primary');
						alert('기사가 보관함에 저장되었습니다.');
					} else {
						icon.textContent = 'bookmark';
						icon.classList.remove('text-primary');
					}
				}
			});
		});
	</script>
</Layout>
