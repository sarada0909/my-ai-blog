---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ko">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="google-site-verification" content="JH4t0PWt4RhBvV9MFUQVBSQWBuAEKupq1n2hsOvhsPs" />
	</head>
	<body class="bg-white text-black antialiased font-sans">
		<header class="border-b border-gray-200 py-6 px-4 mb-8">
			<div class="max-w-4xl mx-auto">
				<a href="/" class="text-3xl font-bold tracking-tighter">AI News Daily</a>
			</div>
		</header>
		<main class="max-w-4xl mx-auto px-4 min-h-screen">
			<slot />
		</main>
		<footer class="border-t border-gray-200 py-8 mt-16 text-center text-sm text-gray-500">
			&copy; {new Date().getFullYear()} AI News Daily. All rights reserved.
		</footer>
	</body>
</html>
